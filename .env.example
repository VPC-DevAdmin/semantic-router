# Per-tier endpoint configuration — one place to point each tier at its
# real backend, regardless of whether it's local-Docker, a remote GPU
# server, or a vendor API.
#
# Copy this file to `.env` (gitignored) and fill in real API keys for the
# providers you want to exercise. python-dotenv auto-loads .env on every
# harness CLI invocation.
#
# ─────────────────────────────────────────────────────────────────────────
# SLOT SCHEME (only one form — no slot 0, no bare TIER{N}_*)
# ─────────────────────────────────────────────────────────────────────────
# Every model a tier fronts is an indexed slot. For tier N, slot i:
#
#   TIER{N}_{i}_URL         OAI-compatible base URL
#   TIER{N}_{i}_MODEL       model id sent in the request body's `model:`
#   TIER{N}_{i}_API_KEY     auth key for the endpoint (leave blank for local)
#   TIER{N}_{i}_PROVIDER    label (Anthropic / OpenAI / Google / …) → demo.json
#   TIER{N}_{i}_TIMEOUT     read timeout in seconds for `make answers`
#   TIER{N}_{i}_MAX_TOKENS  per-slot generation cap for `make answers`
#   TIER{N}_{i}_THINKING    true/false — emit <think> chain (Qwen3 only)
#
# Slots are numbered starting at 1 (TIER{N}_1_*, TIER{N}_2_*, …). They
# must be contiguous; a gap stops discovery. The bare/single form
# (TIER{N}_URL etc.) is no longer supported — the loader raises on it
# with a migration hint, so a stale .env fails loud rather than silently.
#
# Behavior:
#   • The router still picks ONE tier per query. `make answers` then
#     calls EVERY model that tier fronts (slot 1, slot 2, …), so
#     demo.json can show Anthropic vs OpenAI vs Google side by side.
#   • Top-tier-routed queries are SKIPPED by `make answers` (the top
#     tier is the gold reference). Their per-provider gold rows are
#     populated by `make update-gold` (which calls every top-tier model)
#     and by `expected_answers[]` in data/queries.json.
#   • The router itself uses slot 1 of each tier as its canonical
#     backend (the router doesn't fan out — one endpoint per tier).
#
# Per-slot rules:
#   • MODEL is required.
#   • URL is optional; falls back to the tier YAML's endpoint.url.
#   • MODEL must be unique within a tier (it's the per-tier DB / JSON key).
#   • PROVIDER is optional but recommended — it's the label users see.
#   • THINKING is Qwen3-only; a no-op for vendor tiers (their reasoning
#     controls go in the tier YAML's backend.extra_body instead).
#
# ─────────────────────────────────────────────────────────────────────────
# Vendor recipes (paste into any slot)
# ─────────────────────────────────────────────────────────────────────────
# OpenAI:    URL=https://api.openai.com/v1                              MODEL=gpt-5 / gpt-5-mini / gpt-4o      API_KEY=sk-...
# Anthropic: URL=https://api.anthropic.com/v1                           MODEL=claude-opus-4-7 / claude-sonnet-4-5  API_KEY=sk-ant-...
# Google:    URL=https://generativelanguage.googleapis.com/v1beta/openai MODEL=gemini-2.5-pro / gemini-2.5-flash    API_KEY=AIza...
#
# All three speak OAI-compatible JSON + Bearer auth. The builder
# dispatches automatically based on URL (anthropic.com → Anthropic
# adapter; everything else → generic OpenAI-format).
# ─────────────────────────────────────────────────────────────────────────


# ───────────────────────────────────────────────────────────────────────
# Tier 1 — Qwen3-1.7B (local CPU, ZenDNN single-socket)
# Slot 1: managed by `make start_LLM` (docker_vllm_zendnn_single).
# Slot 2: a small cloud model for cross-provider comparison.
# ───────────────────────────────────────────────────────────────────────
TIER1_1_URL=http://localhost:8001/v1
TIER1_1_MODEL=Qwen3-1.7B
TIER1_1_API_KEY=
TIER1_1_PROVIDER=Local-Qwen3
# Tune T1 toward a good answer rather than a fast one. Defaults come
# from config/tiers/tier1.yaml. Example: give the small model room to
# think and finish:
#   TIER1_1_THINKING=true
#   TIER1_1_MAX_TOKENS=4096
#   TIER1_1_TIMEOUT=600
TIER1_1_TIMEOUT=
TIER1_1_MAX_TOKENS=
TIER1_1_THINKING=

TIER1_2_URL=https://api.openai.com/v1
TIER1_2_MODEL=gpt-4o-mini
TIER1_2_API_KEY=
TIER1_2_PROVIDER=OpenAI


# ───────────────────────────────────────────────────────────────────────
# Tier 2 — Qwen3-30B-A3B-Instruct-2507 (local CPU, dual NUMA-pinned)
# Slot 1: managed by `make start_LLM` (docker_vllm_dual_socket).
#         Router talks to r0 at 8002; r1 at 8003 is throughput-only.
# Slot 2: a comparable cloud "mid" model.
# ───────────────────────────────────────────────────────────────────────
TIER2_1_URL=http://localhost:8002/v1
TIER2_1_MODEL=Qwen3-30B-A3B
TIER2_1_API_KEY=
TIER2_1_PROVIDER=Local-Qwen3
# T2 MoE is slow on CPU; tier2.yaml sets a 300s timeout. Raise these if
# you want longer, more complete answers.
TIER2_1_TIMEOUT=
TIER2_1_MAX_TOKENS=
TIER2_1_THINKING=

TIER2_2_URL=https://api.anthropic.com/v1
TIER2_2_MODEL=claude-haiku-4-5
TIER2_2_API_KEY=
TIER2_2_PROVIDER=Anthropic


# ───────────────────────────────────────────────────────────────────────
# Tier 3 — Frontier-mid (cloud only; `backend.kind: remote`)
# Two providers so demo.json can show OpenAI vs Google at this tier.
# ───────────────────────────────────────────────────────────────────────
TIER3_1_URL=https://api.openai.com/v1
TIER3_1_MODEL=gpt-5-mini
TIER3_1_API_KEY=
TIER3_1_PROVIDER=OpenAI
TIER3_1_TIMEOUT=
TIER3_1_MAX_TOKENS=

TIER3_2_URL=https://generativelanguage.googleapis.com/v1beta/openai
TIER3_2_MODEL=gemini-2.5-flash
TIER3_2_API_KEY=
TIER3_2_PROVIDER=Google


# ───────────────────────────────────────────────────────────────────────
# Tier 4 — Frontier-high
# Two providers: Anthropic Sonnet + OpenAI GPT-5.
# ───────────────────────────────────────────────────────────────────────
TIER4_1_URL=https://api.anthropic.com/v1
TIER4_1_MODEL=claude-sonnet-4-5
TIER4_1_API_KEY=
TIER4_1_PROVIDER=Anthropic
TIER4_1_TIMEOUT=
TIER4_1_MAX_TOKENS=

TIER4_2_URL=https://api.openai.com/v1
TIER4_2_MODEL=gpt-5
TIER4_2_API_KEY=
TIER4_2_PROVIDER=OpenAI


# ───────────────────────────────────────────────────────────────────────
# Tier 5 — Gold tier (NOT called by `make answers` — comparisons are
# routed-vs-top, never top-vs-top). These models are called by
# `make update-gold` to produce per-provider expected answers.
# Two providers: Anthropic Opus + OpenAI GPT-5.
# Add a TIER5_3_* block if you want a three-way gold (e.g. + Google).
# ───────────────────────────────────────────────────────────────────────
TIER5_1_URL=https://api.anthropic.com/v1
TIER5_1_MODEL=claude-opus-4-7
TIER5_1_API_KEY=
TIER5_1_PROVIDER=Anthropic
TIER5_1_TIMEOUT=
TIER5_1_MAX_TOKENS=

TIER5_2_URL=https://api.openai.com/v1
TIER5_2_MODEL=gpt-5
TIER5_2_API_KEY=
TIER5_2_PROVIDER=OpenAI
