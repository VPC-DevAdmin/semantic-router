# Per-tier endpoint configuration — one place to point each tier at its
# real backend, regardless of whether it's local-Docker, a remote GPU
# server, or a vendor API.
#
# Copy this file to `.env` (gitignored) and fill in the real values for
# each tier you want to exercise. python-dotenv auto-loads .env on
# every harness CLI invocation.
#
# Three variables per tier (N = level, 1–5):
#   TIER{N}_URL       OAI-compatible base URL, must end in /v1
#   TIER{N}_MODEL     model id sent in the request body's `model:` field
#   TIER{N}_API_KEY   auth key for the endpoint (leave blank for local)
#
# Any blank/unset variable falls back to the YAML default in
# config/tiers/tier{N}.yaml and config/router-backends.yaml. So you only
# need to set the variables you want to override.
#
# These overrides apply to BOTH the harness's direct `make answers`
# calls (read from config/tiers/*.yaml) AND the router's own backend
# table (compiled into config/router-config.yaml from router-backends.yaml).
# ─────────────────────────────────────────────────────────────────────────


# Tier 1 — Qwen3-1.7B (local CPU, ZenDNN single-socket)
# Managed by `make start_LLM` (docker_vllm_zendnn_single).
TIER1_URL=http://localhost:8001/v1
TIER1_MODEL=tier1
TIER1_API_KEY=

# Tier 2 — Qwen3-30B-A3B-Instruct-2507 (local CPU, dual NUMA-pinned replicas)
# Managed by `make start_LLM` (docker_vllm_dual_socket).
# Router talks to r0 at 8002; r1 at 8003 is an extra throughput replica.
TIER2_URL=http://localhost:8002/v1
TIER2_MODEL=tier2
TIER2_API_KEY=

# Tier 3 — external GPU server (e.g. GPT-OSS 120B)
# Not managed by `make start_LLM` (backend.kind: remote). Fill in your
# GPU host once provisioned.
TIER3_URL=
TIER3_MODEL=
TIER3_API_KEY=

# Tier 4 — Claude Sonnet via Anthropic's OAI-compatible endpoint
TIER4_URL=https://api.anthropic.com/v1
TIER4_MODEL=claude-sonnet-4-5
TIER4_API_KEY=

# Tier 5 — Claude Opus via Anthropic's OAI-compatible endpoint
TIER5_URL=https://api.anthropic.com/v1
TIER5_MODEL=claude-opus-4-7
TIER5_API_KEY=
