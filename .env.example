# Per-tier endpoint configuration — one place to point each tier at its
# real backend, regardless of whether it's local-Docker, a remote GPU
# server, or a vendor API.
#
# Copy this file to `.env` (gitignored) and fill in the real values for
# each tier you want to exercise. python-dotenv auto-loads .env on
# every harness CLI invocation.
#
# Variables per tier (N = level, 1–5):
#   TIER{N}_URL         OAI-compatible base URL
#   TIER{N}_MODEL       model id sent in the request body's `model:` field
#   TIER{N}_API_KEY     auth key for the endpoint (leave blank for local)
#   TIER{N}_PROVIDER    optional label (Anthropic/OpenAI/Google) → demo.json
#   TIER{N}_TIMEOUT     read timeout in seconds for `make answers` calls
#   TIER{N}_MAX_TOKENS  per-tier generation cap for `make answers`
#   TIER{N}_THINKING    true/false — let the model emit its <think> chain
#                       (Qwen3 local tiers only; see note below)
#
# ─────────────────────────────────────────────────────────────────────────
# MULTIPLE MODELS PER TIER (indexed slots)
# ─────────────────────────────────────────────────────────────────────────
# The bare TIER{N}_* vars above define slot 0. Add more models to the
# SAME tier with indexed slots — TIER{N}_1_*, TIER{N}_2_*, … each taking
# the same suffixes (URL, MODEL, API_KEY, PROVIDER, TIMEOUT, MAX_TOKENS,
# THINKING). The router still picks ONE tier; `make answers` then calls
# EVERY model that tier fronts, so demo.json shows the answer on
# Anthropic vs OpenAI vs Google side by side, plus a per-provider
# expected answer at the top tier.
#
# Rules:
#   • Slots must be contiguous from 1 (a gap stops discovery).
#   • A slot's URL falls back to slot 0's (same endpoint, different
#     model name); MODEL is required for slots ≥ 1.
#   • MODEL must be unique within a tier (it's the per-tier key in the
#     DB and in demo.json).
#   • PROVIDER is optional but recommended — it's the label users see.
#
# Example — Tier 5 fronted by three providers:
#   TIER5_URL=https://api.anthropic.com/v1
#   TIER5_MODEL=claude-opus-4-7
#   TIER5_API_KEY=sk-ant-...
#   TIER5_PROVIDER=Anthropic
#   TIER5_1_URL=https://api.openai.com/v1
#   TIER5_1_MODEL=gpt-5
#   TIER5_1_API_KEY=sk-...
#   TIER5_1_PROVIDER=OpenAI
#   TIER5_2_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   TIER5_2_MODEL=gemini-2.5-pro
#   TIER5_2_API_KEY=AIza...
#   TIER5_2_PROVIDER=Google
#
# The last three are for tuning a tier toward "good", not "fast". A small
# local model can often produce a solid answer if given a longer timeout,
# a bigger token budget, and (sometimes) permission to think first — so
# the user gets a good answer at the low tier instead of resubmitting at
# a higher one. They only matter for `make answers`; the router itself
# (max_tokens=1 routing probe) is unaffected.
#
#   TIER{N}_THINKING applies to the local Qwen3 tiers (T1/T2 served by
#   vLLM): it flips chat_template_kwargs.enable_thinking, the switch the
#   Qwen3 chat template uses to gate the hidden <think> chain. If you
#   enable thinking, raise TIER{N}_MAX_TOKENS and TIER{N}_TIMEOUT too —
#   the think chain consumes the budget before the visible answer. Vendor
#   reasoning controls (OpenAI reasoning_effort, Anthropic thinking
#   budgets) are out of scope for this var; set those in the tier YAML's
#   backend.extra_body directly.
#
# Any blank/unset variable falls back to the YAML default in
# config/tiers/tier{N}.yaml and config/router-backends.yaml. So you only
# need to set the variables you want to override.
#
# These overrides apply to BOTH the harness's direct `make answers`
# calls (read from config/tiers/*.yaml) AND the router's own backend
# table (compiled into config/router-config.yaml from router-backends.yaml).
#
# ─────────────────────────────────────────────────────────────────────────
# Vendor recipes — paste into any tier's TIER{N}_* slot
# ─────────────────────────────────────────────────────────────────────────
# OpenAI
#   TIER{N}_URL=https://api.openai.com/v1
#   TIER{N}_MODEL=gpt-5-mini                    # or gpt-4o, gpt-4o-mini, etc.
#   TIER{N}_API_KEY=sk-...
#
# Anthropic
#   TIER{N}_URL=https://api.anthropic.com/v1
#   TIER{N}_MODEL=claude-opus-4-7               # or claude-sonnet-4-5, etc.
#   TIER{N}_API_KEY=sk-ant-...
#
# Google (Gemini via the OAI-compatible endpoint)
#   TIER{N}_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   TIER{N}_MODEL=gemini-2.5-flash              # or gemini-2.5-pro, etc.
#   TIER{N}_API_KEY=AIza...
#
# All three share the same wire format (OAI-compatible JSON, Bearer auth);
# the builder dispatches automatically based on URL. Anthropic.com gets
# the vllm-sr Anthropic adapter (OAI→Anthropic shape translation); any
# other HTTPS URL is treated as generic OpenAI-format with Bearer auth,
# which is exactly what OpenAI and Google's OAI-compat endpoint expect.
# ─────────────────────────────────────────────────────────────────────────


# Tier 1 — Qwen3-1.7B (local CPU, ZenDNN single-socket)
# Managed by `make start_LLM` (docker_vllm_zendnn_single).
TIER1_URL=http://localhost:8001/v1
TIER1_MODEL=tier1
TIER1_API_KEY=
# Tune T1 toward a good answer rather than a fast one. Defaults come from
# config/tiers/tier1.yaml (timeout_s, extra_body). Example: give the small
# model room to think and finish —
#   TIER1_THINKING=true
#   TIER1_MAX_TOKENS=4096
#   TIER1_TIMEOUT=600
TIER1_TIMEOUT=
TIER1_MAX_TOKENS=
TIER1_THINKING=

# Tier 2 — Qwen3-30B-A3B-Instruct-2507 (local CPU, dual NUMA-pinned replicas)
# Managed by `make start_LLM` (docker_vllm_dual_socket).
# Router talks to r0 at 8002; r1 at 8003 is an extra throughput replica.
TIER2_URL=http://localhost:8002/v1
TIER2_MODEL=tier2
TIER2_API_KEY=
# T2 (Qwen3-30B-A3B MoE) is slow on CPU; tier2.yaml already sets a 300s
# timeout. Raise these if you want longer, more complete answers.
TIER2_TIMEOUT=
TIER2_MAX_TOKENS=
TIER2_THINKING=

# Tier 3 — external GPU server (e.g. GPT-OSS 120B)
# Not managed by `make start_LLM` (backend.kind: remote). Fill in your
# GPU host once provisioned.
TIER3_URL=
TIER3_MODEL=
TIER3_API_KEY=
# TIMEOUT/MAX_TOKENS are generic (any tier); THINKING is Qwen3-only and a
# no-op for vendor tiers.
TIER3_TIMEOUT=
TIER3_MAX_TOKENS=

# Tier 4 — Claude Sonnet via Anthropic's OAI-compatible endpoint
TIER4_URL=https://api.anthropic.com/v1
TIER4_MODEL=claude-sonnet-4-5
TIER4_API_KEY=
TIER4_TIMEOUT=
TIER4_MAX_TOKENS=

# Tier 5 — Claude Opus via Anthropic's OAI-compatible endpoint
TIER5_URL=https://api.anthropic.com/v1
TIER5_MODEL=claude-opus-4-7
TIER5_API_KEY=
TIER5_TIMEOUT=
TIER5_MAX_TOKENS=
