# Per-tier endpoint configuration — one place to point each tier at its
# real backend, regardless of whether it's local-Docker, a remote GPU
# server, or a vendor API.
#
# Copy this file to `.env` (gitignored) and fill in real API keys for the
# providers you want to exercise. python-dotenv auto-loads .env on every
# harness CLI invocation.
#
# Variables per slot (N = tier level 1–5; i = slot index, omit for slot 0):
#   TIER{N}[_i]_URL         OAI-compatible base URL
#   TIER{N}[_i]_MODEL       model id sent in the request body's `model:`
#   TIER{N}[_i]_API_KEY     auth key for the endpoint (leave blank for local)
#   TIER{N}[_i]_PROVIDER    label (Anthropic / OpenAI / Google / …) → demo.json
#   TIER{N}[_i]_TIMEOUT     read timeout in seconds for `make answers`
#   TIER{N}[_i]_MAX_TOKENS  per-slot generation cap for `make answers`
#   TIER{N}[_i]_THINKING    true/false — emit <think> chain (Qwen3 only)
#
# ─────────────────────────────────────────────────────────────────────────
# MULTIPLE MODELS PER TIER (the whole point of this file)
# ─────────────────────────────────────────────────────────────────────────
# Bare TIER{N}_* = slot 0. Indexed TIER{N}_1_*, TIER{N}_2_*, … add more
# models to the SAME tier. The router still picks ONE tier; `make answers`
# then calls EVERY model that tier fronts, so demo.json shows the answer
# on Anthropic vs OpenAI vs Google side by side for queries routed there.
# For top-tier-routed queries, `make answers` skips them (the top tier is
# the gold reference); their per-provider answers come from
# `make update-gold`, which calls every top-tier model.
#
# Rules:
#   • Slots must be contiguous from 1 (a gap stops discovery).
#   • A slot's URL falls back to slot 0's (same endpoint, different
#     model name); MODEL is required for slots ≥ 1.
#   • MODEL must be unique within a tier (it's the per-tier DB / JSON key).
#   • PROVIDER is optional but recommended — it's the label users see.
#   • THINKING is Qwen3-only; a no-op for vendor tiers (their reasoning
#     controls go in the tier YAML's backend.extra_body instead).
#
# ─────────────────────────────────────────────────────────────────────────
# Vendor recipes (paste into any slot)
# ─────────────────────────────────────────────────────────────────────────
# OpenAI:    URL=https://api.openai.com/v1                              MODEL=gpt-5 / gpt-5-mini / gpt-4o      API_KEY=sk-...
# Anthropic: URL=https://api.anthropic.com/v1                           MODEL=claude-opus-4-7 / claude-sonnet-4-5  API_KEY=sk-ant-...
# Google:    URL=https://generativelanguage.googleapis.com/v1beta/openai MODEL=gemini-2.5-pro / gemini-2.5-flash    API_KEY=AIza...
#
# All three speak OAI-compatible JSON + Bearer auth. The builder
# dispatches automatically based on URL (anthropic.com → Anthropic
# adapter; everything else → generic OpenAI-format).
# ─────────────────────────────────────────────────────────────────────────


# ───────────────────────────────────────────────────────────────────────
# Tier 1 — Qwen3-1.7B (local CPU, ZenDNN single-socket)
# Slot 0: managed by `make start_LLM` (docker_vllm_zendnn_single).
# Slot 1: a small cloud model for cross-provider comparison.
# ───────────────────────────────────────────────────────────────────────
TIER1_URL=http://localhost:8001/v1
TIER1_MODEL=Qwen3-1.7B
TIER1_API_KEY=
TIER1_PROVIDER=Local-Qwen3
# Tune T1 toward a good answer rather than a fast one. Defaults come
# from config/tiers/tier1.yaml. Example: give the small model room to
# think and finish (TIER1_THINKING=true, TIER1_MAX_TOKENS=4096, TIER1_TIMEOUT=600).
TIER1_TIMEOUT=
TIER1_MAX_TOKENS=
TIER1_THINKING=

# Slot 1: small OpenAI model as a comparison point for tier-1 queries.
TIER1_1_URL=https://api.openai.com/v1
TIER1_1_MODEL=gpt-4o-mini
TIER1_1_API_KEY=
TIER1_1_PROVIDER=OpenAI


# ───────────────────────────────────────────────────────────────────────
# Tier 2 — Qwen3-30B-A3B-Instruct-2507 (local CPU, dual NUMA-pinned)
# Slot 0: managed by `make start_LLM` (docker_vllm_dual_socket).
#         Router talks to r0 at 8002; r1 at 8003 is throughput-only.
# Slot 1: a comparable cloud "mid" model.
# ───────────────────────────────────────────────────────────────────────
TIER2_URL=http://localhost:8002/v1
TIER2_MODEL=Qwen3-30B-A3B
TIER2_API_KEY=
TIER2_PROVIDER=Local-Qwen3
# T2 MoE is slow on CPU; tier2.yaml sets a 300s timeout. Raise these if
# you want longer, more complete answers.
TIER2_TIMEOUT=
TIER2_MAX_TOKENS=
TIER2_THINKING=

# Slot 1: Anthropic Haiku as a comparison point for tier-2 queries.
TIER2_1_URL=https://api.anthropic.com/v1
TIER2_1_MODEL=claude-haiku-4-5
TIER2_1_API_KEY=
TIER2_1_PROVIDER=Anthropic


# ───────────────────────────────────────────────────────────────────────
# Tier 3 — Frontier-mid (cloud only; `backend.kind: remote`)
# Two providers so demo.json can show OpenAI vs Google at this tier.
# ───────────────────────────────────────────────────────────────────────
TIER3_URL=https://api.openai.com/v1
TIER3_MODEL=gpt-5-mini
TIER3_API_KEY=
TIER3_PROVIDER=OpenAI
TIER3_TIMEOUT=
TIER3_MAX_TOKENS=

TIER3_1_URL=https://generativelanguage.googleapis.com/v1beta/openai
TIER3_1_MODEL=gemini-2.5-flash
TIER3_1_API_KEY=
TIER3_1_PROVIDER=Google


# ───────────────────────────────────────────────────────────────────────
# Tier 4 — Frontier-high
# Two providers: Anthropic Sonnet + OpenAI GPT-5.
# ───────────────────────────────────────────────────────────────────────
TIER4_URL=https://api.anthropic.com/v1
TIER4_MODEL=claude-sonnet-4-5
TIER4_API_KEY=
TIER4_PROVIDER=Anthropic
TIER4_TIMEOUT=
TIER4_MAX_TOKENS=

TIER4_1_URL=https://api.openai.com/v1
TIER4_1_MODEL=gpt-5
TIER4_1_API_KEY=
TIER4_1_PROVIDER=OpenAI


# ───────────────────────────────────────────────────────────────────────
# Tier 5 — Gold tier (NOT called by `make answers` — comparisons are
# routed-vs-top, never top-vs-top). These models are called by
# `make update-gold` to produce per-provider expected answers.
# Two providers: Anthropic Opus + OpenAI GPT-5 (use GPT-5.5 once available).
# Add a Google entry as TIER5_2_* if you want a three-way gold.
# ───────────────────────────────────────────────────────────────────────
TIER5_URL=https://api.anthropic.com/v1
TIER5_MODEL=claude-opus-4-7
TIER5_API_KEY=
TIER5_PROVIDER=Anthropic
TIER5_TIMEOUT=
TIER5_MAX_TOKENS=

TIER5_1_URL=https://api.openai.com/v1
TIER5_1_MODEL=gpt-5
TIER5_1_API_KEY=
TIER5_1_PROVIDER=OpenAI
