# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtualenv
.venv/
venv/

# Build artifacts
build/
dist/

# Benchmark database (canonical run state — should be regenerable).
# Lives under data/ now; legacy root-level paths kept ignored so a
# stale benchmark.db from earlier checkouts doesn't accidentally land
# in a commit.
data/router_benchmark.db
data/router_benchmark.db-journal
data/router_benchmark.db-wal
data/router_benchmark.db-shm
benchmark.db
benchmark.db-journal
benchmark.db-wal
benchmark.db-shm

# Local config overrides
config/*.local.yaml
.env
.env.*
# Template file is the committed reference for what .env should contain.
!.env.example

# Runtime logs
logs/

# Generated router config — built from config/router-exemplars.yaml +
# config/router-backends.yaml by `make load` / `make route`.
config/router-config.yaml
# vllm-sr's per-config working dir, regenerated alongside router-config.yaml.
config/.vllm-sr/
# Hash of the router-config.yaml the running stack was last launched with.
# Used by `ensure_router_stack` to skip the docker restart on the fast path
# (config unchanged + stack healthy). Local-only state.
.router-config-hash

# vllm-sr's auto-generated artifacts in the project root.
/config.yaml
/.vllm-sr/

# Generated export artifact — re-emitted by `make export`. Legacy
# root-level demo.json kept ignored for old checkouts.
data/evaluated_queries_with_answers.json
demo.json

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Microsoft Office temporary owner/lock files (never commit)
~$*

# Local reference docs / data — kept on disk, not tracked in the repo
Semantic-Router-White-Paper.docx
data/Semantic_router.json
