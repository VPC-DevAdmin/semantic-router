# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtualenv
.venv/
venv/

# Build artifacts
build/
dist/

# Benchmark database. The main .db IS committed — it's the canonical
# dataset (full run lifecycle: queries, routing, per-model answers +
# tokens, gold, evaluations). The WAL / SHM / journal sidecars are
# transient and must NEVER be committed: checkpoint the WAL into the .db
# first (`sqlite3 data/router_benchmark.db 'PRAGMA wal_checkpoint(TRUNCATE)'`)
# so the committed file is self-contained, then commit just the .db.
data/router_benchmark.db-journal
data/router_benchmark.db-wal
data/router_benchmark.db-shm
# Legacy root-level paths (older checkouts) stay fully ignored.
benchmark.db
benchmark.db-journal
benchmark.db-wal
benchmark.db-shm

# Local config overrides
config/*.local.yaml
.env
.env.*
# Template file is the committed reference for what .env should contain.
!.env.example

# Runtime logs
logs/

# Generated router config — built from config/router-exemplars.yaml +
# config/router-backends.yaml by `make load` / `make route`.
config/router-config.yaml
# vllm-sr's per-config working dir, regenerated alongside router-config.yaml.
config/.vllm-sr/
# Hash of the router-config.yaml the running stack was last launched with.
# Used by `ensure_router_stack` to skip the docker restart on the fast path
# (config unchanged + stack healthy). Local-only state. Lives under data/
# now; legacy root-level path kept ignored for older checkouts.
data/.router-config-hash
.router-config-hash

# vllm-sr's auto-generated artifacts in the project root.
/config.yaml
/.vllm-sr/

# NOTE: `data/routed_queries_with_answers.json` is INTENTIONALLY COMMITTED.
# Cloners can inspect the most recent run without re-executing the pipeline.
# `make export` overwrites it in-place — commit the new version when you
# re-run if you want the repo to reflect updated results.
#
# Older export filenames kept ignored so old checkouts don't accidentally
# commit a stale artifact under a defunct name.
data/evaluated_queries_with_answers.json
demo.json

# demo/data/demo_data.json is COMMITTED — it's the canonical, ready-to-serve
# demo dataset so a fresh clone can `make demo` (or just serve demo/) without
# rebuilding. `make demo-data` overwrites it from whatever exports are present;
# running your own pipeline therefore replaces it with your run (git restores
# the canonical copy). Not gitignored — see the demo section in README.

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Microsoft Office temporary owner/lock files (never commit)
~$*

# Local reference docs / data — kept on disk, not tracked in the repo
Semantic-Router-White-Paper.docx
data/Semantic_router.json

# Claude Code local agent/preview state (launch.json, etc.)
.claude/

# Interactive live demo — user overlay (holds API keys) + its build artifacts.
# The committed default is config/live_demo.json; the user's saved version and
# the generated vllm-sr config from it are local-only.
config/live_demo.local.json
config/live_exemplars.local.yaml
